---
---

<section class="relative overflow-hidden px-6 py-28 text-center sm:py-36">
  <!-- Glow blobs -->
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute left-1/2 top-0 h-[600px] w-[900px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-indigo-600/20 blur-3xl"></div>
    <div class="absolute right-0 top-1/3 h-[400px] w-[400px] rounded-full bg-violet-600/15 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-4xl">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-indigo-500/30 bg-indigo-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-indigo-300">
      Now in beta
    </div>

    <h1 class="text-5xl font-extrabold leading-tight tracking-tight sm:text-6xl lg:text-7xl">
      Your AI assistant,
      <span class="bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">
        everywhere
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-[#9090a8] sm:text-xl">
      OneShot connects your AI models — Claude, GPT, Gemini — to your devices, channels, and workflows.
      Local-first. Cloud-powered. Always in sync.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/docs/"
        class="w-full rounded-xl bg-indigo-500 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-indigo-500/25 transition-colors hover:bg-indigo-400 sm:w-auto"
      >
        Get started free
      </a>
      <a
        href="/docs/"
        class="w-full rounded-xl border border-white/10 bg-white/5 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:border-white/20 hover:bg-white/10 sm:w-auto"
      >
        Read the docs
      </a>
    </div>
  </div>

  <!-- Fake terminal screenshot -->
  <div class="mx-auto mt-16 max-w-3xl overflow-hidden rounded-2xl border border-white/[0.07] bg-[#18181f] shadow-2xl shadow-black/60">
    <div class="flex items-center gap-1.5 border-b border-white/[0.07] px-4 py-3">
      <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
      <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
      <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
      <span class="ml-3 text-xs text-[#9090a8]">OneShot Desktop</span>
    </div>
    <div class="px-5 py-5 text-left font-mono text-sm text-[#e2e8f0]">
      <p><span class="text-[#9090a8]">You:</span> Summarise the last 10 Slack messages from #engineering</p>
      <p class="mt-3"><span class="text-indigo-400">AI:</span> <span class="text-[#c4b5fd]">Here's a summary of the last 10 messages…</span></p>
      <p class="mt-3 text-[#9090a8]"><span class="inline-block h-4 w-2 animate-pulse bg-indigo-400 align-middle"></span></p>
    </div>
  </div>
</section>
