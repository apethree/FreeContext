---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SectionFrame from '@/components/SectionFrame.astro';

const docsLinks = [
  { label: 'Getting Started', href: '/getting-started/introduction/', note: 'Install and begin in minutes' },
  { label: 'Desktop Overview', href: '/desktop/overview/', note: 'Understand OneShot desktop capabilities' },
  { label: 'Cloud Overview', href: '/cloud/overview/', note: 'Sessions, sync, channels, and webhooks' },
];
---

<Base title="Docs — OneShot by CapZero" description="Technical documentation for OneShot by CapZero.">
  <Header />
  <main class="py-[72px] sm:py-[96px] lg:py-[120px]">
    <SectionFrame>
      <div class="mx-auto max-w-[760px] text-center">
        <p class="micro-text">Technical docs</p>
        <h1 class="hero-title mt-5">Documentation for OneShot.</h1>
        <p class="lead-text mt-6">
          Learn setup, channels, cloud behavior, and provider configuration.
        </p>
      </div>

      <div class="mx-auto mt-10 grid max-w-[980px] gap-4">
        {docsLinks.map((item) => (
          <a href={item.href} class="soft-card no-underline p-7 transition-all hover:border-[rgba(10,102,255,0.35)] hover:bg-white">
            <p class="text-[26px] leading-[1.1] tracking-[-0.02em] text-[var(--text-strong)]">{item.label}</p>
            <p class="supporting-text mt-3">{item.note}</p>
          </a>
        ))}
      </div>
    </SectionFrame>
  </main>
  <Footer />
</Base>
