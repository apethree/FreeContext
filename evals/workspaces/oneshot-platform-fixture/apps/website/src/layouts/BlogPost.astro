---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  tags: string[];
}

const { title, description, date, author, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const isBlogRoute = Astro.url.pathname.startsWith('/blog/');
const hubHref = isBlogRoute ? '/blog/' : '/news/';
const hubLabel = isBlogRoute ? 'Blog' : 'News';
---

<Base title={`${title} — CapZero ${hubLabel}`} description={description} ogType="article">
  <Header />
  <main class="section-frame max-w-3xl py-16">
    <a href={hubHref} class="text-sm text-[var(--text-muted)] no-underline transition-colors hover:text-[var(--text-strong)]">
      ← Back to {hubLabel}
    </a>
    <div class="mb-4 flex flex-wrap gap-2">
      {tags.map((tag) => <span class="rounded-full bg-[var(--accent-soft)] px-2.5 py-0.5 text-xs font-medium text-[var(--accent)]">{tag}</span>)}
    </div>
    <h1 class="text-4xl font-bold tracking-tight text-[var(--text-strong)] sm:text-5xl">{title}</h1>
    <p class="mt-4 text-lg text-[var(--text-body)]">{description}</p>
    <div class="mt-6 flex items-center gap-3 text-sm text-[var(--text-muted)]">
      <span>{author}</span>
      <span>·</span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <hr class="my-10 border-[var(--line-soft)]" />
    <article class="prose max-w-none prose-headings:font-bold prose-a:text-[var(--accent)] prose-code:rounded prose-code:bg-[var(--surface-muted)] prose-code:px-1 prose-code:py-0.5">
      <slot />
    </article>
  </main>
  <Footer />
</Base>
