{
  "name": "one-shot",
  "productName": "one-shot",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "dev:web": "vite --config vite.renderer.config.ts",
    "dev:web:alt": "ONESHOT_RENDERER_PORT=5174 vite --config vite.renderer.config.ts",
    "dev:worktrees:generate": "node ./scripts/dev-orchestrator/generate-ecosystem.mjs",
    "dev:worktrees:start": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs start",
    "dev:worktrees:stop": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs stop",
    "dev:worktrees:restart": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs restart",
    "dev:worktrees:status": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs status",
    "dev:worktrees:rescan": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs rescan",
    "dev:worktrees:logs": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs logs",
    "dev:worktrees:logs:live": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs logs-live",
    "dev:worktrees:enable": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs enable",
    "dev:worktrees:disable": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs disable",
    "dev:worktrees:profile": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs profile",
    "dev:worktrees:cleanup": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs cleanup-stale",
    "dev:worktrees:monit": "npm exec pm2 monit",
    "dev:worktrees:delete": "node ./scripts/dev-orchestrator/pm2-worktrees.mjs delete",
    "build:web": "vite build --config vite.renderer.config.ts",
    "preview:web": "vite preview --config vite.renderer.config.ts",
    "prepare:runtime": "node ./scripts/prepare-openclaw-runtime.mjs",
    "generate:icons:mac": "node ./scripts/generate-macos-icons.mjs",
    "check:runtime": "node ./scripts/verify-openclaw-runtime.mjs",
    "sync:runtime": "node ./scripts/sync-openclaw-runtime.mjs",
    "update:runtime": "node ./scripts/update-openclaw-runtime.mjs",
    "test:e2e:electron": "playwright test -c playwright.electron.config.ts",
    "test:e2e:web": "playwright test -c playwright.web.config.ts",
    "test:e2e:hosted-phase:clerk-users": "./scripts/test-hosted-phase-clerk-users.sh",
    "test:e2e:electron:headed": "playwright test -c playwright.electron.config.ts --headed",
    "package": "npm run prepare:runtime && npm run check:runtime && electron-forge package",
    "make": "npm run prepare:runtime && npm run check:runtime && electron-forge make",
    "publish": "npm run prepare:runtime && npm run check:runtime && electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "keywords": [],
  "author": {
    "name": "apethree",
    "email": "117607043+apethree@users.noreply.github.com"
  },
  "license": "MIT",
