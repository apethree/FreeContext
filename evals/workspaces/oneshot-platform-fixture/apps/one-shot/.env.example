# =============================================================================
# one-shot — environment variables
# Copy to .env.local and fill in real values.
# .env.local is gitignored and never committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk (required — get from clerk.com dashboard)
# -----------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Dev-only: auto sign-in (never set in production)
# Uses Clerk test OTP flow — only works with test-mode Clerk keys.
# -----------------------------------------------------------------------------
# VITE_DEV_AUTO_SIGNIN=true
# VITE_DEV_AUTO_SIGNIN_EMAIL=test+clerk_test@test.com
# VITE_DEV_AUTO_SIGNIN_OTP=424242

# -----------------------------------------------------------------------------
# Dev server port (default: 5173)
# Override if port 5173 is already in use.
# -----------------------------------------------------------------------------
# ONESHOT_RENDERER_PORT=5173

# -----------------------------------------------------------------------------
# Web runtime endpoints (used by browser build / oneshot.capzero.com)
# -----------------------------------------------------------------------------
VITE_ONESHOT_WS_URL=wss://ws.capzero.com/ws
VITE_ONESHOT_API_URL=https://api.capzero.com

# -----------------------------------------------------------------------------
# Build: OpenClaw runtime injection
# Set ONESHOT_OPENCLAW_RUNTIME_BIN to the path of a pre-built openclaw binary
# before running `npm run package` / `npm run make` / `npm run publish`.
# Alternatively use `npm run sync:runtime <openclaw-repo-root>` to inject from source.
# -----------------------------------------------------------------------------
# ONESHOT_OPENCLAW_RUNTIME_BIN=/path/to/built/openclaw

# -----------------------------------------------------------------------------
# Dev: OpenClaw source repo root (used by `npm run sync:runtime`)
# Set to your local openclaw repo to avoid passing the path as an argument.
# -----------------------------------------------------------------------------
# OPENCLAW_REPO_ROOT=/path/to/openclaw

# -----------------------------------------------------------------------------
# Release: GitHub publishing (required for `npm run publish`)
# GITHUB_TOKEN must have `repo` scope (or `Contents: write` for fine-grained tokens).
# Owner/repo defaults are set in forge.config.ts — override here for forks.
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_RELEASE_OWNER=apethree
# GITHUB_RELEASE_REPO=one-shot

# -----------------------------------------------------------------------------
# macOS code signing + notarization
# Requires a "Developer ID Application" certificate installed in Keychain.
# Team ID: SL864L4ACG (already hardcoded in forge.config.ts).
# App-specific password: generate at appleid.apple.com → App-Specific Passwords.
# Uncomment osxSign / osxNotarize blocks in forge.config.ts when ready.
# -----------------------------------------------------------------------------
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# -----------------------------------------------------------------------------
# Windows code signing (optional — SmartScreen warns without it)
# Point to a .pfx certificate file.
# -----------------------------------------------------------------------------
# WINDOWS_CERTIFICATE_FILE=/path/to/certificate.pfx
# WINDOWS_CERTIFICATE_PASSWORD=your-cert-password

# -----------------------------------------------------------------------------
# E2E tests (Playwright + Electron)
# -----------------------------------------------------------------------------
# ONESHOT_E2E_USER_DATA_DIR=/tmp/oneshot-e2e-user-data
# ONESHOT_E2E_RESET_USER_DATA=true
