NODE_ENV=development

# Service identity
SERVICE_NAME=gateway-realtime
PORT=8080
MACHINE_ID=local-machine

# Clerk
CLERK_JWKS_URL=https://clerk.example.com/.well-known/jwks.json
CLERK_ISSUER=https://clerk.example.com
ELECTRIC_URL=http://127.0.0.1:3000
# Local Electric dev only. Do not use insecure mode outside development.
ELECTRIC_INSECURE=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174,http://127.0.0.1:5175,http://localhost:5175

# Internal auth
INTERNAL_WORKER_BEARER_TOKEN=change-me
INTERNAL_DELIVERY_SECRET=change-me-very-long
OPENCLAW_HOOKS_TOKEN=change-me-hooks-token
OPENCLAW_HOOKS_MAX_PAYLOAD_BYTES=262144
OPENCLAW_HOOKS_AUTH_FAIL_WINDOW_MS=60000
OPENCLAW_HOOKS_AUTH_FAIL_LIMIT=20
OPENCLAW_HOOKS_TRANSFORMS_DIR=

# Data stores
REDIS_URL=redis://127.0.0.1:6379
PG_URL=postgres://postgres:postgres@127.0.0.1:5432/capzero

# Token encryption (32 bytes, base64)
TENANT_TOKEN_ENCRYPTION_KEY_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# S3/Tigris
S3_ENDPOINT=https://fly.storage.tigris.dev
S3_REGION=auto
S3_BUCKET=capzero-gateway
S3_ACCESS_KEY_ID=xxxx
S3_SECRET_ACCESS_KEY=xxxx

# BullMQ
BULLMQ_PREFIX=gateway
BULLMQ_INBOUND_QUEUE=inbound
BULLMQ_OUTBOUND_QUEUE=outbound

# Realtime internal routing
REALTIME_INTERNAL_APP=capzero-gateway-realtime

# Lease tuning
OWNER_LEASE_TTL_MS=300000
OWNER_HEARTBEAT_MS=60000
OWNER_IDLE_GRACE_MS=60000
