{
  "name": "free-context",
  "version": "0.1.0",
  "type": "module",
  "description": "Host-agnostic TypeScript code intelligence engine with symbol indexing, search, call graphs, and MCP server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "free-context": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "eval": "node evals/scripts/run-evals.js",
    "eval:tool": "node evals/scripts/run-tool-evals.js",
    "eval:agent": "node evals/scripts/run-agent-evals.js",
    "eval:braintrust:agent": "node evals/scripts/run-braintrust-agent-evals.js",
    "eval:braintrust:agent:embedding": "node evals/scripts/run-braintrust-agent-embedding-evals.js",
    "eval:braintrust:agent:hybrid": "node evals/scripts/run-braintrust-agent-hybrid-evals.js",
    "eval:braintrust:agent:semantic": "node evals/scripts/run-braintrust-agent-semantic-evals.js",
    "eval:agent:scouts": "node evals/scripts/run-agent-scout-matrix.js",
    "eval:agent:scouts:smoke": "node evals/scripts/run-agent-scout-smoke.js",
    "eval:agent:embedding": "node evals/scripts/run-agent-embedding-evals.js",
    "eval:agent:hybrid": "node evals/scripts/run-agent-hybrid-evals.js",
    "eval:agent:semantic": "node evals/scripts/run-agent-semantic-evals.js",
    "eval:edit": "node evals/scripts/run-edit-evals.js",
    "eval:edit:smoke": "node evals/scripts/run-edit-smoke.js",
    "eval:report": "node evals/scripts/report-eval.js",
    "eval:agent:smoke": "node evals/scripts/run-agent-smoke.js",
    "eval:agent:embedding:smoke": "node evals/scripts/run-agent-embedding-smoke.js",
    "eval:agent:hybrid:smoke": "node evals/scripts/run-agent-hybrid-smoke.js",
    "eval:agent:semantic:smoke": "node evals/scripts/run-agent-semantic-smoke.js",
    "eval:tool:fulltext": "node evals/scripts/run-tool-fulltext-evals.js",
    "eval:tool:fulltext:smoke": "node evals/scripts/run-tool-fulltext-smoke.js",
    "eval:tool:embedding": "node evals/scripts/run-tool-embedding-evals.js",
    "eval:tool:embedding:smoke": "node evals/scripts/run-tool-embedding-smoke.js",
    "eval:tool:hybrid": "node evals/scripts/run-tool-hybrid-evals.js",
    "eval:tool:hybrid:smoke": "node evals/scripts/run-tool-hybrid-smoke.js",
    "eval:tool:embed:health": "node evals/scripts/run-tool-embed-smoke.js",
    "eval:semantic": "node evals/scripts/run-semantic-evals.js",
    "eval:semantic:smoke": "node evals/scripts/run-semantic-smoke.js",
    "eval:tool:embed:smoke": "node evals/scripts/run-tool-embed-smoke.js",
    "eval:view": "npx promptfoo view",
    "mcp:smoke": "node --input-type=module -e \"import { Client } from '@modelcontextprotocol/sdk/client/index.js'; import { StreamableHTTPClientTransport } from '@modelcontextprotocol/sdk/client/streamableHttp.js'; const serverUrl = process.env.MCP_SERVER_URL ?? 'http://127.0.0.1:3100/mcp'; const client = new Client({ name: 'free-context-smoke', version: '1.0.0' }); await client.connect(new StreamableHTTPClientTransport(new URL(serverUrl))); const tools = await client.listTools(); const checks = [['search_code', { query: 'CodeIntelEngine', limit: 3 }], ['find_symbol', { name: 'CodeIntelEngine' }], ['who_calls', { symbolName: 'contentHash' }], ['search_paths', { query: 'core', pathPrefix: 'src/', limit: 5 }], ['codebase_map', {}]]; const results = {}; for (const [name, args] of checks) { const result = await client.callTool({ name, arguments: args }); results[name] = result.structuredContent; } console.log(JSON.stringify({ serverUrl, tools: tools.tools.map((tool) => tool.name), results }, null, 2)); await client.close();\"",
    "docs:dev": "astro dev",
    "docs:build": "astro build",
    "docs:preview": "astro preview",
    "eval:agent:openai": "node evals/scripts/run-agent-evals.js --group openai",
    "eval:agent:anthropic": "node evals/scripts/run-agent-evals.js --group anthropic",
    "eval:ui": "node evals/scripts/run-eval-control-ui.js"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^13.1.0",
    "glob": "^11.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@astrojs/starlight": "^0.38.1",
    "@openai/codex-sdk": "^0.113.0",
    "@types/node": "^24.0.0",
    "astro": "^6.0.4",
    "braintrust": "^3.4.0",
    "promptfoo": "^0.121.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "keywords": [
    "code-intelligence",
    "tree-sitter",
    "typescript",
    "mcp",
    "symbol-search",
    "call-graph"
  ]
}
